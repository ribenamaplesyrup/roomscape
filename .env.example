# Local development defaults. Docker and Railway override HOST to 0.0.0.0.
HOST=127.0.0.1
PORT=8787

# Optional local overrides. By default these live under .roomscape/.
# ROOMSCAPE_DATA_DIR=.roomscape
# ROOMSCAPE_DATA_PATH=.roomscape/data.json
# ROOMSCAPE_CODEX_AUTH_DIR=.roomscape/codex-auth
# ROOMSCAPE_WORKSPACE_DIR=.roomscape/workspaces

# Local development defaults to browser ChatGPT auth. Hosted production defaults
# to device_code so users authenticate through https://auth.openai.com/codex/device.
# ROOMSCAPE_CHATGPT_LOGIN_FLOW=browser

# Railway containers do not allow Codex's bubblewrap workspace sandbox. Use this
# only in hosted environments that still validate generated paths and source.
# ROOMSCAPE_CODEX_SANDBOX_MODE=danger-full-access

# Set DATABASE_URL to use PostgreSQL instead of the local JSON store.
# DATABASE_URL=postgres://user:password@host:5432/database
# Optional when using an external PostgreSQL endpoint that requires TLS.
# Railway private Postgres URLs normally do not need this.
# ROOMSCAPE_DATABASE_SSL=require
