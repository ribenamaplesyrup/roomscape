HOST=0.0.0.0
PORT=8787
ROOMSCAPE_DATA_DIR=/data
# Production defaults to device_code so Railway users authenticate with ChatGPT
# through https://auth.openai.com/codex/device instead of a localhost callback.
# Local development can force browser to reuse the Codex-managed popup flow.
ROOMSCAPE_CHATGPT_LOGIN_FLOW=device_code
ROOMSCAPE_CODEX_AUTH_DIR=/data/codex-auth
ROOMSCAPE_WORKSPACE_DIR=/data/workspaces
# Railway containers do not allow Codex's bubblewrap workspace sandbox.
# Roomscape still validates generated scene paths and source before promotion.
ROOMSCAPE_CODEX_SANDBOX_MODE=danger-full-access

# DATABASE_URL=postgres://user:password@host:5432/database
# Optional when using an external PostgreSQL endpoint that requires TLS.
# Railway private Postgres URLs normally do not need this.
# ROOMSCAPE_DATABASE_SSL=require
